{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "screenshots": "node scripts/screenshots.mjs",
    "lint": "oxlint src/",
    "fmt": "oxfmt --write src/",
    "fmt:check": "oxfmt --check src/"
  },
  "pnpm": {
    "executionEnv": {
      "nodeVersion": "22.16.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@antv/g6": "^5.0.51",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@shikijs/rehype": "^4.0.1",
    "beautiful-mermaid": "^1.1.3",
    "bob-wasm": "^1.0.1",
    "d3": "^7.9.0",
    "github-markdown-css": "^5.8.1",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.0.0",
    "katex": "^0.16.37",
    "mermaid": "^11.12.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-github-alerts": "^4.2.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gemoji": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "playwright": "^1.58.2",
    "rollup-plugin-license": "^3.7.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
